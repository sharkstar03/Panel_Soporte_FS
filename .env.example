# ─────────────────────────────────────────────────────────────────────────────
# Configuración de Panel de Soporte — copia este archivo a .env y complétalo.
#
#   cp .env.example .env
#
# Genera secretos fuertes (NUNCA reutilices el mismo valor en dos variables):
#   openssl rand -hex 32
# ─────────────────────────────────────────────────────────────────────────────

# Entorno: "production" (por defecto, validaciones estrictas) o "development".
APP_ENV=production

# Secreto para firmar los JWT. Mínimo 32 caracteres aleatorios.
JWT_SECRET=

# Clave maestra para cifrar la bóveda de secretos (passwords, OTP, llaves,
# credenciales remotas, SMTP). DEBE ser distinta de JWT_SECRET. Mínimo 32 chars.
# ¡No la cambies después de guardar secretos o no podrás descifrarlos!
MASTER_KEY=

# Orígenes permitidos para CORS (separados por coma). NO uses "*" en producción.
# Ej: https://panel.midominio.com,https://app.midominio.com
CORS_ORIGINS=

# Credenciales del administrador inicial (bootstrap). Usa una contraseña fuerte.
BOOTSTRAP_ADMIN=true
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Base de datos PostgreSQL.
POSTGRES_DB=soporte
POSTGRES_USER=soporte
POSTGRES_PASSWORD=

# ── Desarrollo con Supabase local (Supabase CLI: `supabase start`) ────────────
# Si en vez del Postgres del docker-compose quieres usar el stack local de
# Supabase, arranca `supabase start` y apunta el backend a su Postgres (puerto
# 54322, usuario/clave por defecto "postgres"). Descomenta:
# DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:54322/postgres
# Studio:  http://127.0.0.1:54323   ·   Emails de prueba: http://127.0.0.1:54324

# Opcionales
JWT_EXPIRES_MINUTES=720
MAX_UPLOAD_MB=25
# Timeout de sentencias de PostgreSQL (ms)
# DB_STATEMENT_TIMEOUT_MS=30000
# SSL hacia la DB (para DB gestionada/remota): require | verify-full
# DB_SSLMODE=
# API_PORT=8000
# FRONTEND_PORT=3000
# DB_PORT=5432

# S3 / MinIO (opcional — si no se define, se usa almacenamiento local)
# S3_ENDPOINT_URL=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=support-attachments
# S3_REGION=us-east-1
